# ─── Supabase Edge Function Secrets ─────────────────────────────────────────
# Set these via: supabase secrets set
# Or via Supabase Dashboard > Edge Functions > Secrets
#
# Usage:
#   supabase secrets set DANA_ENV=sandbox \
#     X_PARTNER_ID=your_client_id \
#     DANA_PRIVATE_KEY="$(cat server/keys/private_key.pem)" \
#     DANA_PUBLIC_KEY="$(cat server/keys/dana_public_key.pem)" \
#     FRONTEND_URL=https://your-frontend-url.com \
#     FUNCTION_URL=https://your-project.supabase.co/functions/v1/dana

# DANA environment: 'sandbox' or 'production'
DANA_ENV=sandbox

# Your DANA Client ID (from dashboard.dana.id/sandbox)
X_PARTNER_ID=

# RSA Private Key content (from DANA sandbox — include PEM headers)
# The Edge Function will strip headers/footers automatically
DANA_PRIVATE_KEY=

# RSA Public Key content (from DANA sandbox — for webhook verification)
DANA_PUBLIC_KEY=

# Your frontend URL (for redirect page postMessage)
FRONTEND_URL=http://localhost:3000

# This function's own public URL (used as ORIGIN header)
# Format: https://<project-ref>.supabase.co/functions/v1/dana
FUNCTION_URL=

# ─── Frontend .env (React app) ──────────────────────────────────────────────
# Add this to your React app's .env file:
#
# REACT_APP_DANA_FUNCTION_URL=https://<project-ref>.supabase.co/functions/v1/dana
#
# If not set, falls back to local Express server at http://localhost:4000/api/dana
